# Copy to .env for local development.
# In production, set these in Cloudflare Pages:
# Workers & Pages → wandora-workspace → Settings → Environment variables

# Client-side gate passwords (embedded in the JS bundle at build time)
VITE_TEAM_PASSWORD=your-team-password
VITE_CONFIG_PASSWORD=your-config-password

# Server-side password for write API (Cloudflare Pages Function only).
# Copy .dev.vars.example to .dev.vars for local API development.
# In production, set CONFIG_PASSWORD in Cloudflare Pages environment variables.

# One-time KV setup (run from project root):
#   npx wrangler kv namespace create WORKSPACE_KV
#   npx wrangler kv namespace create WORKSPACE_KV --preview
# Then replace the placeholder IDs in wrangler.toml and bind WORKSPACE_KV
# in the Cloudflare Pages project settings.

# --- GitHub Actions CI/CD secrets (Settings → Secrets and variables → Actions) ---
#
# CLOUDFLARE_API_TOKEN   API token with "Cloudflare Pages: Edit" permission
# CLOUDFLARE_ACCOUNT_ID  Your Cloudflare account ID (dashboard sidebar)
# VITE_TEAM_PASSWORD     Same value as above (used at build time in CI)
# VITE_CONFIG_PASSWORD   Same value as above (used at build time in CI)
#
# Also set CONFIG_PASSWORD in Cloudflare Pages → Settings → Environment variables
# (Production + Preview) — this is a runtime secret for the /api/data function.
