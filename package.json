{
  "name": "landing-page",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler pages dev dist --compatibility-date=2026-07-10 --port 8788",
    "dev:full": "wrangler pages dev --proxy 5173 --compatibility-date=2026-07-10",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=wandora-workspace",
    "deploy:preview": "npm run build && wrangler pages deploy dist --project-name=wandora-workspace --branch=preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11",
    "wrangler": "^4.110.0"
  }
}
